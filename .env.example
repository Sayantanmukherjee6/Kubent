# =============================================================================
# Kubernetes Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- LLM Provider Selection ---
# Options: "llama_cpp" or "openai"
LLM_PROVIDER=llama_cpp

# --- Local llama.cpp Server ---
# The llama.cpp server must be running before starting the agent.
# Default llama.cpp server port is 8080.
LLAMA_CPP_BASE_URL=http://localhost:8080/v1
LLAMA_CPP_MODEL_NAME=./models/your-model.gguf

# --- OpenAI API (for later use) ---
# Only needed when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o

# --- Mock Log Simulation ---
# Number of log lines to generate during a simulation run
MOCK_LOG_COUNT=50
# Severity levels to include in mock logs: "info", "warning", "error", "critical"
MOCK_LOG_SEVERITIES=info,warning,error,critical
